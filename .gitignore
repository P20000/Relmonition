# --- Root .gitignore ---

# Node.js
node_modules/
dist/
build/
.pnpm-store/
npm-debug.log*

# Environment & Secrets (CRITICAL)
.env
.env.*
!.env.example

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfplan
*.tfvars
.terraform.tfstate.lock.info

# Kubernetes/Helm
charts/*/charts/
charts/*/tmp/

# Docker
.docker/

# System/IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# OS/Logs
*.log
*.tmp
*.bak

# next.js build output
.next/
out/

# Relmonition specific
server/scratch/
server/dist/
server/.env

# typescript
*.tsbuildinfo
next-env.d.ts

# vercel
.vercel