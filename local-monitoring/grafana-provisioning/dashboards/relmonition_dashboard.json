  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 10,
      "title": "Application Metrics (Custom)",
      "type": "row"
    },
    {
      "type": "timeseries",
      "title": "Active Sessions (Concurrency)",
      "id": 1,
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "relmonition_active_sessions",
          "legendFormat": "Active Sessions",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Volume (RPS)",
      "id": 2,
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(rate(relmonition_http_requests_total[1m])) by (route, method, status)",
          "legendFormat": "{{method}} {{route}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Request Latency P95 / P99",
      "id": 3,
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(relmonition_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "P95 Latency",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(relmonition_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "P99 Latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "s"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 20,
      "title": "Runtime Telemetry (NodeJS)",
      "type": "row"
    },
    {
      "type": "timeseries",
      "title": "Process CPU Usage",
      "id": 4,
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 9 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(process_cpu_seconds_total[1m]) * 100",
          "legendFormat": "CPU Usage %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          },
          "unit": "percent"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Heap Memory Usage",
      "id": 5,
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 9 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "Used Heap",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "nodejs_heap_size_total_bytes",
          "legendFormat": "Total Heap",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "bytes"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Event Loop Lag",
      "id": 6,
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 9 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "Lag",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          },
          "unit": "s"
        }
      }
    }
  ],
  "refresh": "5s",
